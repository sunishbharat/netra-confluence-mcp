CONFLUENCE_BASE_URL=https://your-org.atlassian.net
CONFLUENCE_SITE_URL=https://your-org.atlassian.net
LOG_LEVEL=INFO
JSON_LOGS=false

# stdio for local MCP clients (Claude Desktop, CLI); http for CF/HTTP deployment
SERVER_TRANSPORT=stdio
SERVER_HOST=127.0.0.1
SERVER_PORT=8765

# CONFLUENCE_API_TOKEN / CONFLUENCE_USER_EMAIL - required only for SERVER_TRANSPORT=stdio.
# Each team member runs the server as their own local stdio process, so these are that
# person's own credentials - every edit is attributed to them in Confluence, not a shared
# account. Create a token at: Atlassian account -> Security -> API tokens.
#
# On SERVER_TRANSPORT=http, leave these unset. The server owns no Confluence identity;
# each request supplies its own via the X-Confluence-User-Email / X-Confluence-Api-Token
# headers instead (see "Production transport (http)" in README.md). Setting them here would
# have no effect on http - there is no fallback to a shared identity, by design.
CONFLUENCE_API_TOKEN=your-api-token-here
CONFLUENCE_USER_EMAIL=your-email@example.com
